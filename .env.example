# ============================================
# Gemini Business2API 环境变量示例
# ============================================

# 必填：管理后台登录密码。
ADMIN_KEY=your-admin-secret-key

# 可选：主 2API 服务对外暴露端口。
# PORT=7860

# 可选：主服务 BASE_URL 覆盖值。
# BASE_URL=http://localhost:7860

# ============================================
# 存储
# ============================================

# 推荐用于多机器部署，或 refresh-worker 运行在当前 compose 之外时使用。
# 留空则默认使用本地 SQLite。
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# 可选：覆盖 SQLite 路径。默认主服务使用 data/data.db。
# SQLITE_PATH=./data/data.db

# ============================================
# 可选 refresh-worker 镜像 / 服务
# 启动方式：
# docker compose --profile refresh up -d
# ============================================

# 可选：独立 refresh-worker 使用的 Docker 镜像。
# REFRESH_WORKER_IMAGE=cooooookk/gemini-refresh-worker:latest

# 可选：worker 健康检查端口，映射到宿主机。
# REFRESH_HEALTH_PORT=8080

# 可选：强制开启 / 关闭定时刷新，优先级高于面板设置。
# FORCE_REFRESH_ENABLED=true

# 可选：worker 侧覆盖配置。留空时，worker 会读取后台系统设置中的共享值。
# REFRESH_INTERVAL_MINUTES=30
# REFRESH_WINDOW_HOURS=1
# BROWSER_HEADLESS=true
# PROXY_FOR_AUTH=socks5h://127.0.0.1:7890

# ============================================
# 各类配置分别在哪里设置
# ============================================

# 1) 管理后台 -> 系统设置
#    主服务共享配置、刷新共享配置、邮箱默认配置都放这里。
#
# 2) 管理后台 -> 账号管理
#    账号级导入 / 导出字段放这里，包括：
#    mail_provider, mail_address, mail_password, mail_client_id,
#    mail_refresh_token, mail_base_url, mail_api_key, mail_jwt_token,
#    mail_verify_ssl, mail_domain 等账号级字段。
#
# 3) Worker 环境变量
#    仅在 refresh-worker 需要机器本地覆盖配置时再使用。
